{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "center",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,
  "control-center-width": 700,
  "control-center-height": 500,
  "control-center-margin-top": 36,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,
  "notification-window-width": 480,
  "timeout": 5,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "keyboard-shortcuts": false,
  "image-visibility": "when-available",
  "transition-time": 100,
  "hide-on-clear": true,
  "hide-on-action": true,
  "text-empty": "No Notifications",
  "widgets": [
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰆴"
    }
  }
}